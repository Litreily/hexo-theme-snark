script(type='text/javascript', src=url_for(theme.js) + '/search.js', defer)
script(type='text/javascript', src=url_for(theme.js) + '/top.js', defer)

if theme.busuanzi
    script(type='text/javascript', src='//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js', async)

if theme.local_search == true
    script.
        var search_path = '#{config.search.path}';
        if (search_path.length == 0) {
            search_path = 'search.xml';
        }
        var path = '#{config.root}' + search_path;
        searchFunc(path, 'local-search-input', 'local-search-result');

if theme.fancybox == true
    script(defer).
        document.addEventListener('DOMContentLoaded', function () {
            // Fancybox v4: auto-bind all content images (skip nofancybox class)
            Fancybox.bind('.p-content img:not(.nofancybox)', {
                groupAll: true,
                Toolbar: {
                    display: {
                        left:  ['infobar'],
                        middle: [],
                        right: ['slideshow', 'download', 'fullscreen', 'close'],
                    },
                },
                Thumbs: { type: 'classic' },
                animated: true,
            });
        });
