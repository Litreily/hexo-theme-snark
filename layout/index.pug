extends base

block title
    title= config.title

block content
    include _partial/common.pug
    .l-postlist
        each post in page.posts.toArray()
            .l-post
                .p-desc.box
                    //- Cover image (set 'cover: /path/img.jpg' in post front-matter)
                    if post.cover
                        .p-pic
                            a(href=url_for(post.path))
                                img(src=post.cover alt=post.title loading='lazy')
                    //- Title
                    h1.p-title
                        a(href=url_for(post.path))
                            +title(post)
                    //- Excerpt / description
                    if post.description
                        .p-content
                            != post.description
                    else if post.excerpt
                        .p-content
                            != post.excerpt
                    else if post.content
                        - var br = 0
                        - for (var i = 0; i < 5; ++i) {
                            - br = post.content.indexOf('\n', br + 1)
                            if br < 0
                                - break
                            if br > 150
                                - break
                        - }
                        if br < 0
                            .p-content
                                != post.content
                        else
                            .p-content
                                != post.content.substring(0, br)
                    //- Read more
                    p.p-readmore
                        a(href=url_for(post.path)) 阅读全文 →

                +post-meta(post)

    include _partial/paginator.pug
